source "https://rubygems.org"

# Use the github-pages gem so local builds match GitHub Pages exactly.
gem "github-pages", group: :jekyll_plugins

# Lock down to a Jekyll version compatible with github-pages.
gem "jekyll", "~> 3.10"

# Windows / JRuby helpers (harmless on macOS).
gem "tzinfo", ">= 1", "< 3"
gem "tzinfo-data"
gem "wdm", "~> 0.1.1", platforms: [:mingw, :x64_mingw, :mswin]

# Faster local rebuilds on macOS.
gem "ffi"
